# ==============================================================================
# AUTO SPARE - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ==============================================================================

# --- Database (catalog — public, non-PII) ---
DATABASE_URL=postgresql+asyncpg://autospare:PASSWORD@localhost:5432/autospare

# --- Database (PII — users, orders, payments — GDPR separation) ---
DATABASE_PII_URL=postgresql+asyncpg://autospare_pii:PASSWORD@localhost:5432/autospare_pii

# --- Redis ---
REDIS_URL=redis://:PASSWORD@localhost:6379

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (PBKDF2/Fernet) ---
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_Fernet.generate_key()

# --- AI (Hugging Face Inference API) ---
HF_TOKEN=hf_your_token_here
HF_TEXT_MODEL=moonshotai/Kimi-K2-Instruct-0905
WEB_AI_MODEL=
WHATSAPP_AI_MODEL=
TELEGRAM_AI_MODEL=
HF_VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct
HF_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
HF_AUDIO_MODEL=openai/whisper-large-v3
HF_CLIP_MODEL=openai/clip-vit-large-patch14
HF_TEXT_CACHE_TTL=3600
HF_EMBED_CACHE_TTL=86400
HF_MAX_RETRIES=3

# --- Fitment External Source Lane (Step 5) ---
EXTERNAL_FITMENT_PROVIDER_URLS=https://www.autodoc.eu/api/v1/part/applicability,https://www.buycarparts.co.uk/api/v1/part/applicability
EXTERNAL_PASS_BRAND_LIMIT=2
EXTERNAL_PASS_PARTS_PER_BRAND=3
EXTERNAL_PASS_INCLUDE_POST_PLAN=0
EXTERNAL_ENABLE_NHTSA=true
NHTSA_API_BASE=https://vpic.nhtsa.dot.gov/api
EXTERNAL_ENABLE_EBAY=true
EBAY_BROWSE_API_BASE=https://api.ebay.com/buy/browse/v1
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_BEARER_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope/buy.browse
EBAY_IDENTITY_BASE=https://api.ebay.com/identity/v1
EXTERNAL_ENABLE_ROCKAUTO=true
ROCKAUTO_CROSSREF_ENDPOINT_TEMPLATE=
ROCKAUTO_ITEMS_PATH=items
EXTERNAL_ENABLE_OEM_EPC=true
OEM_EPC_ENDPOINT_TEMPLATES=
OEM_EPC_ITEMS_PATH=items
STEP4_NIGHTLY_KEEP_RUNS=14

# --- GitHub ---
GITHUB_TOKEN=github_pat_CHANGE_ME

# --- Twilio (2FA SMS + WhatsApp) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_here        # for SMS 2FA
USE_TWILIO_MESSAGING_SERVICE=false                # keep false unless your Messaging Service is fully configured
TWILIO_MESSAGING_SERVICE_SID=
ENABLE_WHATSAPP_2FA=false                         # trial WhatsApp requires sandbox opt-in
TWO_FA_BRAND_ICON=🔧
TWO_FA_LOGO_URL=
TWO_FA_MESSAGE_TEMPLATE=שלום {name}, קוד האימות שלך ל-AutoSpare הוא {code}. תוקף הקוד {minutes} דקות. אין לשתף קוד זה עם אף גורם.
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886      # Twilio sandbox or approved WhatsApp sender

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=support@autospare.com
SENDGRID_FROM_NAME=Auto Spare

# --- Business Rules (DO NOT CHANGE without approval) ---
VAT_PERCENTAGE=18
PROFIT_MARGIN_PERCENTAGE=45
DEFAULT_SHIPPING_COST_ILS=91
CURRENCY_EXCHANGE_RATE_USD_TO_ILS=3.65

# --- Company Info ---
COMPANY_NAME=Auto Spare
COMPANY_NUMBER=060633880
COMPANY_ADDRESS=הרצל 55, עכו
COMPANY_PHONE=+972-XX-XXX-XXXX
COMPANY_EMAIL=info@autospare.com

# --- Environment ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Security ---
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
TWO_FA_CODE_EXPIRY_MINUTES=10
TRUST_DEVICE_DAYS=180
PASSWORD_MIN_LENGTH=8

# --- Israeli Government API (vehicle lookup) ---
DATA_GOV_IL_BASE_URL=https://data.gov.il/api/3/action/datastore_search
VEHICLE_DATASET_ID=053cea08-09bc-40ec-8f7a-156f0677aff3

# --- File Storage ---
UPLOAD_DIR=/tmp/autospare_uploads
MAX_FILE_SIZE_MB=25
# --- Catalog Scraper ---
# Enable/disable the background price scraper
SCRAPE_ENABLED=true
# Hours between full scraper cycles (6 = every 6 hours)
SCRAPE_INTERVAL_H=6
# Parts processed per cycle (spread API load)
SCRAPE_BATCH_SIZE=200
# Seconds to wait between individual HTTP requests (be polite to sources)
SCRAPE_REQUEST_DELAY=1.5
# Abort a cycle after this many consecutive errors
SCRAPE_MAX_ERRORS=30
# USD → ILS exchange rate used by the scraper (auto-updated by fetch_ils_exchange_rate)
USD_TO_ILS=3.72

# --- Returns Policy (per Refund Policy v1.0, Feb 2026) ---
# Days after delivery customer can open a return  (Israeli Consumer Protection Law §14a = 14 days)
RETURN_WINDOW_DAYS=14
# Comma-separated reason codes that qualify for 100% refund (seller pays return shipping)
RETURN_FULL_REFUND_REASONS=defective,wrong_part,damaged_in_transit
# Handling fee % applied to non-fault returns (changed_mind, not_as_described, duplicate_order)
RETURN_PARTIAL_REFUND_PERCENT=90
# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=change_me_in_production

# --- Telegram Bot (social media publishing) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_or_chat_id
# Optional: validates inbound Telegram webhook header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=

# --- Super Admin Bootstrap (used by create_superuser.py) ---
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_NAME=Admin Name
SUPERUSER_PHONE=+972-XX-XXX-XXXX
SUPERUSER_PASSWORD=

# --- Dev helpers (remove or leave empty in production) ---
# Set to a fixed code to skip real SMS during development
DEV_2FA_CODE=
