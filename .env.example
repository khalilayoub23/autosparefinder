# Production databases — separate catalog DB and PII DB
DATABASE_URL=postgresql+asyncpg://autospare:${DB_PASSWORD}@localhost:5432/autospare
DATABASE_PII_URL=postgresql+asyncpg://autospare:${DB_PASSWORD}@localhost:5432/autospare_pii
DB_PASSWORD=change_me_strong_password
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change_me_redis_password

# JWT — REQUIRED in production (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=
JWT_REFRESH_SECRET_KEY=

ENCRYPTION_KEY=your-32-byte-base64-encryption-key
OLLAMA_URL=http://YOUR_VPS_IP:11434  # Ollama on VPS — set once server is provisioned

# Twilio 2FA
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe payments — REQUIRED for checkout
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# SendGrid email (password reset)
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=support@autospare.com
FRONTEND_URL=http://localhost:5173

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Django scaffold (only needed if using manage.py)
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

GOV_API_KEY=your-gov-api-key
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
ENVIRONMENT=development

# Exchange rate (optional — defaults to 3.65)
USD_TO_ILS=3.65
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_SIZE_MB=25
FILE_EXPIRY_DAYS=30
VAT_PERCENTAGE=17
PROFIT_MARGIN_PERCENTAGE=45
DEFAULT_SHIPPING_COST_ILS=91
CURRENCY_EXCHANGE_RATE_USD_TO_ILS=3.65

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=change_me_in_production
